model UserSession {
  id         String   @id @default(cuid())
  userId     String   
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent  String?
  refreshTokenHash String   @unique  // хешированный JWT{}
  ip         String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime

  @@index([userId])
  @@index([refreshTokenHash])
}